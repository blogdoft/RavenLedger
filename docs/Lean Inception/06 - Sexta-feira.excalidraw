    {
      "id": "g5j2gIbx8zGJQ26_eDtBT",
      "type": "text",
      "x": 3123.499999999999,
      "y": 199.75,
      "width": 669.51953125,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aa",
      "roundness": null,
      "seed": 452801922,
      "version": 583,
      "versionNonce": 1423754050,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772310971248,
      "link": null,
      "locked": false,
      "text": "Para peritos em geral/compliance\ncujo interese é identificar quem, o quê quando e porquê determinada \nmanipulação de dados ocorreu\nO RavenLedger é um sistema de auditoria de dados/TI, via browser\nque permite a identificação e localização de dados alterados por \nprocessos ou pessoas. Diferente do EntityFramework (e similares)\nnosso produto oferece uma interface amigável para o usuário. Seus \nprocessos internos garantem a legitimidade dos dados auditados",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Para peritos em geral/compliance\ncujo interese é identificar quem, o quê quando e porquê determinada \nmanipulação de dados ocorreu\nO RavenLedger é um sistema de auditoria de dados/TI, via browser\nque permite a identificação e localização de dados alterados por \nprocessos ou pessoas. Diferente do EntityFramework (e similares)\nnosso produto oferece uma interface amigável para o usuário. Seus \nprocessos internos garantem a legitimidade dos dados auditados",
      "autoResize": true,
      "lineHeight": 1.25
    },
