    },
    {
      "id": "2YuOO8kza_MofOtYp_RPr",
      "type": "text",
      "x": -8151.400210138246,
      "y": -6265.091773367762,
      "width": 712.3918051092523,
      "height": 200,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "#1e1e1e",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1j",
      "roundness": null,
      "seed": 54294013,
      "version": 156,
      "versionNonce": 700143059,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772309911667,
      "link": null,
      "locked": false,
      "text": "Regra 1: Uma wave pode conter no máximo três cards.\nRegra 2: Uma wave não pode conter mais de um card vermelho.\nRegra 3: Uma wave não pode conter três cards se nenhum for verde.\nRegra 4: A quantidade de esforço nos cards não pode exceder cinco Es.\nRegra 5: A soma do valor dos cards de uma wave não pode ser inferior a\ncinco $ e cinco corações.\nRegra 6: Se um card depender de outro card, esse outro card deve\nestar em uma wave anterior.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Regra 1: Uma wave pode conter no máximo três cards.\nRegra 2: Uma wave não pode conter mais de um card vermelho.\nRegra 3: Uma wave não pode conter três cards se nenhum for verde.\nRegra 4: A quantidade de esforço nos cards não pode exceder cinco Es.\nRegra 5: A soma do valor dos cards de uma wave não pode ser inferior a cinco $ e cinco corações.\nRegra 6: Se um card depender de outro card, esse outro card deve estar em uma wave anterior.",
      "autoResize": false,
      "lineHeight": 1.25
    },
