      "boundElements": [],
      "updated": 1783809785014,
      "link": null,
      "locked": false,
      "text": "Linguagem Frontend",
      "fontSize": 73.62213491204719,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Linguagem Frontend",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "yAT3LnvMe2aZV9HfWIumq",
      "type": "text",
      "x": 11622.071860101207,
      "y": 1030.2032861732123,
      "width": 908.9412841796856,
      "height": 311.1111111111108,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3G",
      "roundness": null,
      "seed": 4604359,
      "version": 2237,
      "versionNonce": 2074173449,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783809785014,
      "link": null,
      "locked": false,
      "text": "A utilização de TypeScript permite uma escrita padronizada\ne com validação em tempo de \"compilação\" do projeto.\n\nAngular é um framework fortemente utilizado em\ndesenvolvimento Enterprise, além de diminuir\nconsideravelmente a fricção de transição entre linguagens.\nC#, TypeScript e o \"jeito Angular de escrever código\" são\nmuito próximos.",
      "fontSize": 31.11111111111108,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A utilização de TypeScript permite uma escrita padronizada e com validação em tempo de \"compilação\" do projeto.\n\nAngular é um framework fortemente utilizado em desenvolvimento Enterprise, além de diminuir consideravelmente a fricção de transição entre linguagens. C#, TypeScript e o \"jeito Angular de escrever código\" são muito próximos.",
      "autoResize": false,
      "lineHeight": 1.25
    },
