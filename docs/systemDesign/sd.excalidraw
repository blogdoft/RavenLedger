      "index": "b2j",
      "roundness": null,
      "seed": 274394202,
      "version": 586,
      "versionNonce": 100199386,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777245208106,
      "link": null,
      "locked": false,
      "text": "As aplicações devem utilizar KeyCloak para criação de um\ntoken de serviço que garanta a autenticidade de quem está\nenviando o evento para o Ledger.",
      "fontSize": 31.11111111111108,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "As aplicações devem utilizar KeyCloak para criação de um token de serviço que garanta a autenticidade de quem está enviando o evento para o Ledger.",
      "autoResize": false,
      "lineHeight": 1.25
    },
