    },
    {
      "id": "sjJLntmY3T_MPQxRHf72w",
      "type": "text",
      "x": 4518.504410659839,
      "y": 1633.1367554396545,
      "width": 1184.09521484375,
      "height": 77.5611623128257,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#2a5da7",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
