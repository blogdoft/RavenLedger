    {
      "id": "_eO8V_OHE23nmImBaTUbl",
      "type": "text",
      "x": 9440.931658877837,
      "y": 2398.5558274325253,
      "width": 1509.227783203125,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#2a5da7",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b39",
      "roundness": null,
      "seed": 992329321,
      "version": 3923,
      "versionNonce": 1361783273,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783808948929,
      "link": null,
      "locked": false,
      "text": "Flagr é uma solução OpenSource que permite, de maneira simples e fácil, a utilização de\ntécnicas como Teste A/B, Canary Release, Feature Flags e etc.\n\nPensando em entrega continua e habilitar o sistema para teste, vamos utilizar o Flagr\ncomo solução.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Flagr é uma solução OpenSource que permite, de maneira simples e fácil, a utilização de\ntécnicas como Teste A/B, Canary Release, Feature Flags e etc.\n\nPensando em entrega continua e habilitar o sistema para teste, vamos utilizar o Flagr\ncomo solução.",
      "autoResize": true,
      "lineHeight": 1.25
    },
