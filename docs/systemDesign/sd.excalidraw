    {
      "id": "7FLC85dKxU6Rzq05KApdv",
      "type": "text",
      "x": 9431.354309896247,
      "y": 1459.6272560039545,
      "width": 1537.45166015625,
      "height": 270,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#2a5da7",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b30",
      "roundness": null,
      "seed": 43669449,
      "version": 2916,
      "versionNonce": 2121516489,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783808261813,
      "link": null,
      "locked": false,
      "text": "Permitem uma ambiente seguro para governança dos deploys. Keda pode adicionar\nfuncionalidades de escala automática para além dos clássicos \"memória e/ou cpu\",\nadicionando condicionais baseadas nos tópicos e o tempo de consumo das mensagens.\n\nPelas características de atribuição de consumidores do Kafka, a soma de poderes\npode tornar a aplicação altamente escalável quando passar por picos de processamento.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Permitem uma ambiente seguro para governança dos deploys. Keda pode adicionar\nfuncionalidades de escala automática para além dos clássicos \"memória e/ou cpu\",\nadicionando condicionais baseadas nos tópicos e o tempo de consumo das mensagens.\n\nPelas características de atribuição de consumidores do Kafka, a soma de poderes\npode tornar a aplicação altamente escalável quando passar por picos de processamento.",
      "autoResize": true,
      "lineHeight": 1.25
    },
