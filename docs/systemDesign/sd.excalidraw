    {
      "id": "YK9A0pM1k5HZDOiyer78o",
      "type": "text",
      "x": 355.67810601061865,
      "y": 1619.4588024416134,
      "width": 869.2813811658158,
      "height": 77.03666687011719,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#2a5da7",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
