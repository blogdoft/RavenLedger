    },
    {
      "id": "SUaAMnCJ1AnTGqfwyV2od",
      "type": "text",
      "x": 1815.2767886207198,
      "y": -1214.5450800663605,
      "width": 1196.2076416015625,
      "height": 315,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0g",
      "roundness": null,
      "seed": 1734918111,
      "version": 849,
      "versionNonce": 1562092383,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772559926334,
      "link": null,
      "locked": false,
      "text": "Volumetria Transacional\n - Imprevisível: A variedade de contextos gera volumetria distintas. \n   - Sistemas Bancário: > Milhões de registros diários\n   - Industria:\n     - IoT: Milhões de registros diários por planta\n     - Processos: De poucos a milhares de registros diários\n",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Volumetria Transacional\n - Imprevisível: A variedade de contextos gera volumetria distintas. \n   - Sistemas Bancário: > Milhões de registros diários\n   - Industria:\n     - IoT: Milhões de registros diários por planta\n     - Processos: De poucos a milhares de registros diários\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "eIk1Z9dPJjSOVESchuYem",
      "type": "text",
      "x": 1810.7585129510776,
      "y": -903.0774461377893,
      "width": 1214.2117745535713,
      "height": 450,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0h",
      "roundness": null,
      "seed": 1602677233,
      "version": 805,
      "versionNonce": 1739833727,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772560339968,
      "link": null,
      "locked": false,
      "text": "Volumetria Auditoria\n - Caso raro: Um registro Transacional = 1 registro de Auditoria\n(Insert)\n - Melhor caso: Um registro Transacional = 4 registros de Auditoria\n(Insert + 3x Update)\n - Caso médio: Um registro Transacional = 5 registros de Auditoria\n(Insert + 3x Update + Delete)\n - Pior caso: Um registro Transacional = N+1 operações de Auditoria\n(Insert + N operações sobre o registro)\n",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Volumetria Auditoria\n - Caso raro: Um registro Transacional = 1 registro de Auditoria (Insert)\n - Melhor caso: Um registro Transacional = 4 registros de Auditoria (Insert + 3x Update)\n - Caso médio: Um registro Transacional = 5 registros de Auditoria (Insert + 3x Update + Delete)\n - Pior caso: Um registro Transacional = N+1 operações de Auditoria (Insert + N operações sobre o registro)\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "Zr8XnBE0Y7vVTHgbhF0nN",
