    {
      "id": "SjKAogCETNCX3Gttxcivz",
      "type": "text",
      "x": 9568.01808292443,
      "y": -807.3623972328323,
      "width": 908.9412841796856,
      "height": 116.66666666666654,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
