      "isDeleted": false,
      "boundElements": [],
      "updated": 1776628571546,
      "link": null,
      "locked": false,
      "text": "Postgres é realmente a melhor escolha?",
      "fontSize": 62.048929850260556,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Postgres é realmente a melhor escolha?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Smeff-BEheIuJ6Gnm_CMq",
      "type": "text",
      "x": 4573.909565108669,
      "y": 1735.8693194960163,
      "width": 1327.3558349609375,
      "height": 450,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#2a5da7",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2U",
      "roundness": null,
      "seed": 1747864870,
      "version": 1265,
      "versionNonce": 1752062054,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776628772960,
      "link": null,
      "locked": false,
      "text": "A intenção é desenvolver o MVP, da forma mais rápida e simples possível.\nAcredito que Bancos Relacionais AINDA são a solução mais simples e comum\nentre as novas pessoas da área. Então quero seguir com Postgres.\n\nNo entanto, sua adoção pode trazer dificuldades em processos como:\n- Sharding (por tenant, tempo e etc);\n- Full Text Searching;\n- Pesquisas de dados em campos alterados;\n\nO que vai nos \"forçar\" a fazer algumas coisas na mão.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A intenção é desenvolver o MVP, da forma mais rápida e simples possível.\nAcredito que Bancos Relacionais AINDA são a solução mais simples e comum\nentre as novas pessoas da área. Então quero seguir com Postgres.\n\nNo entanto, sua adoção pode trazer dificuldades em processos como:\n- Sharding (por tenant, tempo e etc);\n- Full Text Searching;\n- Pesquisas de dados em campos alterados;\n\nO que vai nos \"forçar\" a fazer algumas coisas na mão.",
      "autoResize": true,
      "lineHeight": 1.25
    },
