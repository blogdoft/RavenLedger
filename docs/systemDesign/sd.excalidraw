    {
      "id": "wCVDsJJo8kasFA1S27XFp",
      "type": "text",
      "x": 5326.6951175265895,
      "y": -463.8818831670826,
      "width": 708.8888888888887,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2s",
      "roundness": null,
      "seed": 774022535,
      "version": 305,
      "versionNonce": 607811473,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1784479384359,
      "link": null,
      "locked": false,
      "text": "Isso numa distribuição equilibrada. O que acontece na vida real é termos\npicos de produção de dados durante o dia. Seria necessário um estudo\n\"caso à caso\" já que a média não nos prepara para o cenário de pico -\nonde a resiliência é exigida.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Isso numa distribuição equilibrada. O que acontece na vida real é termos  picos de produção de dados durante o dia. Seria necessário um estudo \"caso à caso\" já que a média não nos prepara para o cenário de pico - onde a resiliência é exigida.",
      "autoResize": false,
      "lineHeight": 1.25
    },
