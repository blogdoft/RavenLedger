      "text": "Gestão de segredos",
      "fontSize": 73.62213491204719,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Gestão de segredos",
      "autoResize": true,
