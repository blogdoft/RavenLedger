      "text": "Todas as APIs\nrepondendo em\nmenos de 200ms",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "U9Ry9vKh8ixZmlBz1XBvB",
      "originalText": "Todas as APIs repondendo em menos de 200ms",
      "autoResize": true,
