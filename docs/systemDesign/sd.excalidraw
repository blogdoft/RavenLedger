    {
      "id": "yfuOAQOpMaQZ7i6icuBzg",
      "type": "text",
      "x": 9457.432226628545,
      "y": -450.4684752029632,
      "width": 908.9412841796856,
      "height": 388.8888888888885,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2n",
      "roundness": null,
      "seed": 1419610694,
      "version": 1285,
      "versionNonce": 1502900063,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1784481335330,
      "link": null,
      "locked": false,
      "text": "Nenhum segredo deve ser versionado. Mesmo aqueles que\nconfiguram ambiente local.\nOs segredos dos ambientes produtivos devem ser\narmazenados no OpenBao, com a aplicação acessando\ndiretamente o vault e baixando os segredos.\nJá os segredos locais devem ser armazenados em arquivos\n`.env` que JAMAIS serão versionados. Para cada `.env`\nesperado, no mesmo nível do repositório haverá um\n`.env.template`, apenas com os nomes das secrets e sem\nvalor real atribuído.",
      "fontSize": 31.11111111111108,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Nenhum segredo deve ser versionado. Mesmo aqueles que configuram ambiente local.\nOs segredos dos ambientes produtivos devem ser armazenados no OpenBao, com a aplicação acessando diretamente o vault e baixando os segredos.\nJá os segredos locais devem ser armazenados em arquivos `.env` que JAMAIS serão versionados. Para cada `.env` esperado, no mesmo nível do repositório haverá um `.env.template`, apenas com os nomes das secrets e sem valor real atribuído.",
      "autoResize": false,
      "lineHeight": 1.25
    },
