    {
      "id": "T3vpczewcB5bGHNt-dTOe",
      "type": "text",
      "x": 11308.827321120458,
      "y": 1416.7214629477542,
      "width": 705.2059326171875,
      "height": 92.02766864005898,
      "angle": 0,
      "strokeColor": "#1e1e1e",
