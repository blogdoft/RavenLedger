      "boundElements": [],
      "updated": 1763338075959,
      "link": null,
      "locked": false,
      "text": "Escala: O consumer pode engargalar se o volume de mensagens\nfor muito alto. Precisa existir uma estragégia para dividir a carga;\n\nPreferencialmente, as mensagens devem seguir e manter a ordem em que chegam;",
      "fontSize": 4.0321168334233874,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Escala: O consumer pode engargalar se o volume de mensagens\nfor muito alto. Precisa existir uma estragégia para dividir a carga;\n\nPreferencialmente, as mensagens devem seguir e manter a ordem em que chegam;",
      "autoResize": true,
      "lineHeight": 1.25
    },
